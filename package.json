{
  "name": "automation-exercise-qa-framework",
  "version": "1.0.0",
  "description": "End-to-end and API test automation framework for automationexercise.com, built with Playwright + TypeScript. Portfolio project for Middle+ QA Engineer roles.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:ui:all-browsers": "playwright test --project=ui-chromium --project=ui-firefox --project=ui-webkit",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --project=ui-chromium --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["playwright", "typescript", "qa-automation", "e2e-testing", "api-testing"],
  "author": "Pavlo Lysenko",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@faker-js/faker": "^9.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  }
}
